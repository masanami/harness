{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "indent": ["error", 2],
    "camelcase": ["error", { "properties": "always" }],
    "no-unused-vars": ["warn", { "vars": "all", "args": "none" }],
    "no-undef": "error"
  }
}
