# Codex CLI プロジェクト設定テンプレート
# このファイルをプロジェクトルートの .codex/ にコピーして config.toml として使用してください。

model = "o4-mini"
sandbox_mode = "workspace-write"
approval_policy = "unless-allow-listed"

# エージェント定義
# 各エージェントの詳細設定は .codex/agents/*.toml を参照

[agents.code-reviewer]
description = "ソースコードをレビューする際に使用。「コードをレビューして」「実装をチェックして」「PRをレビューして」といったレビュー依頼時に自動委譲される。"
config_file = ".codex/agents/code-reviewer.toml"

[agents.design-reviewer]
description = "設計レビューを行う際に使用。「設計をレビューして」「アーキテクチャを確認して」「依存関係をチェックして」といった設計レビュー依頼時に自動委譲される。"
config_file = ".codex/agents/design-reviewer.toml"

[agents.implement-feature]
description = "新規機能を実装する際に使用。「〇〇機能を実装して」「〇〇を新しく作って」「〇〇機能を追加して」といった新規実装依頼時に自動委譲される。"
config_file = ".codex/agents/implement-feature.toml"

[agents.modify-feature]
description = "既存機能に変更を加える際に使用。「〇〇機能を修正して」「〇〇を変更して」「〇〇のバグを直して」といった機能変更依頼時に自動委譲される。"
config_file = ".codex/agents/modify-feature.toml"

[agents.doc-verifier]
description = "実装とドキュメント（要件定義・設計書）の整合性を確認する際に使用。「ドキュメントと整合性を確認して」「設計書と実装が合っているか確認して」といった依頼時に自動委譲される。"
config_file = ".codex/agents/doc-verifier.toml"

